# ================================================
# .env для Telegram-бота 3x-ui-tg-client-pay
# ================================================
# Reality-настройки подтягиваются из inbound автоматически.
# Нужны только: токен бота, токен панели, ID inbound.

# === Telegram ===
BOT_TOKEN=<токен_бота_от_BotFather>
PAYMENT_TOKEN=<платёжный_токен_от_BotFather>
# Telegram ID администраторов через запятую.
# Администраторы видят команду /orders и кнопку проверки заказов.
ADMINS=<ваш_telegram_id>

# === Ручная проверка заказов / тарифы ===
# Оставьте пустым, чтобы использовать тарифы по умолчанию из src/config.py.
# Формат: JSON-массив тарифов с key, label, duration_days и amount.
# key — короткий уникальный код тарифа для callback-кнопки.
# label — текст тарифа, который увидят пользователь и администратор.
# duration_days — на сколько дней продлить подписку после подтверждения платежа.
# amount — сумма к оплате в рублях.
# Русский вариант:
# SUBSCRIPTION_PLANS='[{"key":"1w","label":"1 неделя","duration_days":7,"amount":100},{"key":"2w","label":"2 недели","duration_days":14,"amount":180},{"key":"1m","label":"1 месяц","duration_days":30,"amount":270},{"key":"3m","label":"3 месяца","duration_days":90,"amount":700},{"key":"6m","label":"полгода","duration_days":180,"amount":1200}]'
# English variant:
# SUBSCRIPTION_PLANS='[{"key":"1w","label":"1 week","duration_days":7,"amount":100},{"key":"2w","label":"2 weeks","duration_days":14,"amount":180},{"key":"1m","label":"1 month","duration_days":30,"amount":270},{"key":"3m","label":"3 months","duration_days":90,"amount":700},{"key":"6m","label":"6 months","duration_days":180,"amount":1200}]'
SUBSCRIPTION_PLANS=

# === 3x-ui Panel ===
XUI_API_URL=http://localhost:<PANEL_INTERNAL_PORT>
XUI_API_TOKEN=<токен_панели>
XUI_HOST=<VLESS_SERVER_NAME>
XUI_BASE_PATH=/panel
XUI_SERVER_NAME=<PANEL_SERVER_NAME>
XUI_SUB_PORT=<VLESS_WS_UPSTREAM_PORT>
SUBSCRIPTION_URL_BASE=<PANEL_SERVER_NAME>
XUI_VERIFY_SSL=False
INBOUND_ID=1

# Database
DB_PATH=/app/data/users.db

# === Временные профили ===
TEMP_INBOUND_ID=<ID_временного_inbound>
TEMP_REALITY_PUBLIC_KEY=<public_key_временного_inbound>
TEMP_REALITY_SNI=<sni_временного_inbound>
TEMP_REALITY_SHORT_ID=<short_id_временного_inbound>
TEMP_REALITY_FINGERPRINT=chrome
TEMP_REALITY_SPIDER_X=/
TEMP_WEB_SERVER_PORT=8080
TEMP_SSL_CERT_PATH=<путь_к_ssl_сертификату>
TEMP_SSL_KEY_PATH=<путь_к_ssl_ключу>

# === Админ-панель ===
ADMIN_PANEL_PASSWORD=<сильный_пароль>
ENABLE_CODE_EDITOR=false
