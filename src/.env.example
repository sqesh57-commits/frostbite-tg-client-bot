# ==================================================
# Frostbite Telegram VPN bot environment example
# Пример .env для Frostbite Telegram VPN bot
# ==================================================
# RU: Скопируйте этот файл в src/.env и заполните реальные значения.
# EN: Copy this file to src/.env and fill in real values.

# === Telegram / Telegram ===
# RU: Токен Telegram-бота от @BotFather.
# EN: Telegram bot token from @BotFather.
# Example / Пример: BOT_TOKEN=1234567890:AAExampleToken
BOT_TOKEN=

# RU: Платёжный токен от @BotFather. Если используются ручные переводы на карту, можно оставить пустым.
# EN: Payment provider token from @BotFather. Leave empty when using manual card transfers only.
# Example / Пример: PAYMENT_TOKEN=390540000:LIVE:00000
PAYMENT_TOKEN=

# RU: Telegram ID администраторов через запятую; они видят /orders и кнопку проверки заказов.
# EN: Comma-separated Telegram admin IDs; admins see /orders and the order review button.
# Example / Пример: ADMINS=247789673,123456789
ADMINS=

# === Manual order review / Ручная проверка заказов ===
# RU: Номер карты для ручного перевода, показывается пользователю при создании заказа.
# EN: Card number for manual transfers, shown to users when an order is created.
# Example / Пример: PAYMENT_CARD_NUMBER=2200700012345678
PAYMENT_CARD_NUMBER=

# RU: Имя получателя перевода, показывается пользователю.
# EN: Card holder / recipient name shown to users.
# Example / Пример: PAYMENT_CARD_HOLDER=IVAN I.
PAYMENT_CARD_HOLDER=

# RU: true — просить пользователя указать код платежа в комментарии к переводу.
# EN: true asks users to include the payment code in the transfer comment.
# Example / Пример: PAYMENT_COMMENT_REQUIRED=true
PAYMENT_COMMENT_REQUIRED=true

# RU: Тестовые тарифы для ручной проверки заказов. Оставьте пустым, чтобы использовать тарифы по умолчанию из src/config.py.
# EN: Test tariffs for manual order review. Leave empty to use default tariffs from src/config.py.
# RU: Формат JSON: key, label, duration_days, amount. duration_days продлевает подписку после подтверждения.
# EN: JSON format: key, label, duration_days, amount. duration_days extends the subscription after approval.
# RU example:
# SUBSCRIPTION_PLANS='[{"key":"1w","label":"1 неделя","duration_days":7,"amount":100},{"key":"2w","label":"2 недели","duration_days":14,"amount":180},{"key":"1m","label":"1 месяц","duration_days":30,"amount":270},{"key":"3m","label":"3 месяца","duration_days":90,"amount":700},{"key":"6m","label":"полгода","duration_days":180,"amount":1200}]'
# EN example:
# SUBSCRIPTION_PLANS='[{"key":"1w","label":"1 week","duration_days":7,"amount":100},{"key":"2w","label":"2 weeks","duration_days":14,"amount":180},{"key":"1m","label":"1 month","duration_days":30,"amount":270},{"key":"3m","label":"3 months","duration_days":90,"amount":700},{"key":"6m","label":"6 months","duration_days":180,"amount":1200}]'
SUBSCRIPTION_PLANS=

# === 3x-ui API / API панели 3x-ui ===
# RU: URL API 3x-ui. В Docker обычно внутренний адрес сервиса; без Docker — адрес панели.
# EN: 3x-ui API URL. In Docker this is usually the internal service URL; outside Docker use the panel URL.
# Example / Пример: XUI_API_URL=http://3x-ui-allinone:21443
XUI_API_URL=http://3x-ui-allinone:21443

# RU: Базовый путь панели 3x-ui.
# EN: Base path of the 3x-ui panel.
# Example / Пример: XUI_BASE_PATH=/panel
XUI_BASE_PATH=/panel

# RU: Токен API панели 3x-ui, если используется авторизация токеном.
# EN: 3x-ui API token when token-based authorization is used.
# Example / Пример: XUI_API_TOKEN=your_api_token
XUI_API_TOKEN=

# RU: Логин панели 3x-ui, если используется вход по логину/паролю.
# EN: 3x-ui username when username/password login is used.
# Example / Пример: XUI_USERNAME=admin
XUI_USERNAME=admin

# RU: Пароль панели 3x-ui.
# EN: 3x-ui panel password.
# Example / Пример: XUI_PASSWORD=strong_password
XUI_PASSWORD=

# RU: Проверять SSL-сертификат при подключении к панели.
# EN: Verify SSL certificate when connecting to the panel.
# Example / Пример: XUI_VERIFY_SSL=False
XUI_VERIFY_SSL=False

# RU: Публичный домен/адрес VLESS-сервера для генерации ссылок.
# EN: Public VLESS server hostname/address for generated links.
# Example / Пример: XUI_HOST=vless.example.com
XUI_HOST=vless.example.com

# RU: ServerName/SNI панели или домена, если требуется в ссылках/подписках.
# EN: Panel/domain server name or SNI when required by links/subscriptions.
# Example / Пример: XUI_SERVER_NAME=panel.example.com
XUI_SERVER_NAME=panel.example.com

# === 3x-ui inbound / Inbound 3x-ui ===
# RU: Основной inbound ID для создания VPN-профилей.
# EN: Primary inbound ID used to create VPN profiles.
# Example / Пример: INBOUND_ID=3
INBOUND_ID=3

# RU: Несколько inbound ID через запятую, если профиль нужно создавать сразу в нескольких inbound.
# EN: Comma-separated inbound IDs when profiles should be created in multiple inbounds.
# Example / Пример: INBOUND_IDS=3,4
INBOUND_IDS=3,4

# RU: Группа клиентов в 3x-ui, куда бот добавляет созданные профили.
# EN: 3x-ui client group for profiles created by the bot.
# Example / Пример: BOT_GROUP_NAME=tg_bot_users
BOT_GROUP_NAME=tg_bot_users

# === Subscription links / Ссылки подписки ===
# RU: Базовый публичный URL подписки. Если пусто, бот соберёт URL из XUI_HOST/XUI_SUB_PATH/XUI_SUB_PORT.
# EN: Public subscription base URL. If empty, the bot builds it from XUI_HOST/XUI_SUB_PATH/XUI_SUB_PORT.
# Example / Пример: SUBSCRIPTION_URL_BASE=https://panel.example.com:20576
SUBSCRIPTION_URL_BASE=https://panel.example.com:20576

# RU: Путь подписки 3x-ui.
# EN: 3x-ui subscription path.
# Example / Пример: XUI_SUB_PATH=/sub/
XUI_SUB_PATH=/sub/

# RU: Публичный порт подписки, если отличается от стандартного.
# EN: Public subscription port when it differs from the default.
# Example / Пример: XUI_SUB_PORT=20576
XUI_SUB_PORT=

# === Reality fallback / Резервные Reality-настройки ===
# RU: Обычно бот читает Reality-настройки из 3x-ui API; заполните только если нужен fallback.
# EN: The bot normally reads Reality settings from 3x-ui API; fill these only as fallback.
# Example / Пример: REALITY_PUBLIC_KEY=abcdef...
REALITY_PUBLIC_KEY=
# Example / Пример: REALITY_SNI=www.microsoft.com
REALITY_SNI=
# Example / Пример: REALITY_SHORT_ID=0123456789abcdef
REALITY_SHORT_ID=
# Example / Пример: REALITY_FINGERPRINT=chrome
REALITY_FINGERPRINT=chrome
# Example / Пример: REALITY_SPIDER_X=/
REALITY_SPIDER_X=/

# === Temporary profiles / Временные профили ===
# RU: Inbound ID для временных/тестовых профилей.
# EN: Inbound ID for temporary/test profiles.
# Example / Пример: TEMP_INBOUND_ID=4
TEMP_INBOUND_ID=4
# RU/EN: Fallback Reality public key for temporary profiles.
# Example / Пример: TEMP_REALITY_PUBLIC_KEY=abcdef...
TEMP_REALITY_PUBLIC_KEY=
# RU/EN: Fallback Reality SNI for temporary profiles.
# Example / Пример: TEMP_REALITY_SNI=www.microsoft.com
TEMP_REALITY_SNI=
# RU/EN: Fallback Reality short ID for temporary profiles.
# Example / Пример: TEMP_REALITY_SHORT_ID=0123456789abcdef
TEMP_REALITY_SHORT_ID=
# RU/EN: Reality fingerprint for temporary profiles.
# Example / Пример: TEMP_REALITY_FINGERPRINT=chrome
TEMP_REALITY_FINGERPRINT=chrome
# RU/EN: Reality spiderX for temporary profiles.
# Example / Пример: TEMP_REALITY_SPIDER_X=/
TEMP_REALITY_SPIDER_X=/
# RU: Порт встроенного web-сервера временных профилей.
# EN: Embedded temporary-profile web server port.
# Example / Пример: TEMP_WEB_SERVER_PORT=8080
TEMP_WEB_SERVER_PORT=8080
# RU: Путь к SSL-сертификату для временного web-сервера, если нужен HTTPS.
# EN: SSL certificate path for temporary web server when HTTPS is needed.
# Example / Пример: TEMP_SSL_CERT_PATH=/etc/ssl/certs/fullchain.pem
TEMP_SSL_CERT_PATH=
# RU: Путь к SSL-ключу для временного web-сервера, если нужен HTTPS.
# EN: SSL key path for temporary web server when HTTPS is needed.
# Example / Пример: TEMP_SSL_KEY_PATH=/etc/ssl/private/privkey.pem
TEMP_SSL_KEY_PATH=

# === Optional external nginx BasicAuth / Опциональный BasicAuth nginx ===
# RU: Логин BasicAuth внешнего nginx перед панелью. Обычно не нужен при внутреннем Docker URL.
# EN: BasicAuth username for an external nginx in front of the panel. Usually not needed with internal Docker URL.
# Example / Пример: NGINX_BASIC_AUTH_USER=admin
NGINX_BASIC_AUTH_USER=
# RU: Пароль BasicAuth внешнего nginx.
# EN: BasicAuth password for external nginx.
# Example / Пример: NGINX_BASIC_AUTH_PASSWORD=strong_password
NGINX_BASIC_AUTH_PASSWORD=

# === Database / База данных ===
# RU: Путь к SQLite базе внутри контейнера/сервера.
# EN: SQLite database path inside the container/server.
# Example / Пример: DB_PATH=/app/data/users.db
DB_PATH=/app/data/users.db

# === Local admin panel / Локальная админ-панель ===
# RU: Пароль локальной админ-панели Streamlit. Если пусто, панель может быть доступна без авторизации.
# EN: Local Streamlit admin panel password. If empty, the panel may be available without authorization.
# Example / Пример: ADMIN_PANEL_PASSWORD=strong_admin_password
ADMIN_PANEL_PASSWORD=
# RU: Включить редактор кода в админ-панели.
# EN: Enable code editor in the admin panel.
# Example / Пример: ENABLE_CODE_EDITOR=false
ENABLE_CODE_EDITOR=false

# === Safety flags / Флаги безопасности ===
# RU: Разрешить полное обновление inbound в 3x-ui. По умолчанию выключено для безопасности.
# EN: Allow full inbound update in 3x-ui. Disabled by default for safety.
# Example / Пример: XUI_ALLOW_FULL_INBOUND_UPDATE=false
XUI_ALLOW_FULL_INBOUND_UPDATE=false
# RU: Тестовый режим: бот логирует действия, но не создаёт/не меняет клиентов в 3x-ui.
# EN: Dry-run mode: logs actions without creating/updating 3x-ui clients.
# Example / Пример: BOT_DRY_RUN=false
BOT_DRY_RUN=false
# RU: Требовать админские/бизнес-проверки перед self-service созданием VPN-профиля.
# EN: Require admin/business checks before self-service VPN profile creation.
# Example / Пример: BOT_REQUIRE_ADMIN_FOR_PROFILE_CREATE=false
BOT_REQUIRE_ADMIN_FOR_PROFILE_CREATE=false
# RU: Telegram ID пользователей через запятую, которым запрещено self-service создание профиля.
# EN: Comma-separated Telegram IDs blocked from self-service profile creation.
# Example / Пример: BOT_BLOCKED_PROFILE_CREATE_IDS=111111,222222
BOT_BLOCKED_PROFILE_CREATE_IDS=
# RU: Минимальный интервал между попытками создания профиля одним пользователем.
# EN: Minimum interval between profile creation attempts by one user.
# Example / Пример: BOT_PROFILE_CREATE_RATE_LIMIT_SECONDS=60
BOT_PROFILE_CREATE_RATE_LIMIT_SECONDS=60
# RU: Максимум VPN-профилей на пользователя в self-service режиме.
# EN: Maximum VPN profiles per user in self-service mode.
# Example / Пример: BOT_MAX_PROFILES_PER_USER=1
BOT_MAX_PROFILES_PER_USER=1
# RU: Длительность пробного периода для новых пользователей в днях.
# EN: Trial period length for new users in days.
# Example / Пример: TRIAL_DAYS=3
TRIAL_DAYS=3
